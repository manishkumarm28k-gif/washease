                        <div class="nav-dropdown" style="padding: 1rem 0; cursor: pointer;">
                            <a href="/services" style="text-decoration: none; color: #0f172a; transition: color 0.2s;" onmouseover="this.style.color='#f97316'" onmouseout="this.style.color='#0f172a'">Our Services <i class="fas fa-caret-down ml-1 small" style="color: #f97316;"></i></a>
                            <div class="nav-dropdown-menu" style="min-width: 260px;">
                                <a href="/services" class="nav-dropdown-item">Laundry Service</a>
