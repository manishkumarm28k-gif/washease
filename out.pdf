                </nav>
            

            <main class="page-content">
                <div class="flash-messages">
                    
                        
                            
                                <div class="alert alert-info">
                                    Please log in to access this page.
                                </div>
                            
                        
                    
                </div>
                
                
<div class="d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="card shadow p-4" style="width: 100%; max-width: 450px;">
        <h2 class="text-center mb-4">Welcome Back</h2>
        <form method="POST" action="">
            <input id="csrf_token" name="csrf_token" type="hidden" value="IjA5M2YxODMyYTNjZGM1MzYyOWFkMWRjZGU0MzlmNTRhN2IwNDk5NDQi.ab_UgQ.V8kMOJnKeZFwtLgWrj2wtxSOMNA">
            
            <div class="form-group">
                <label class="form-label" for="email">Email</label>
                
                    <input class="form-control" id="email" name="email" placeholder="Enter your email" required type="text" value="">
                
            </div>
            
            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                
                    <input class="form-control" id="password" name="password" placeholder="Enter your password" required type="password" value="">
                
            </div>
            
            <div class="form-check">
                <input class="form-check-input" id="remember" name="remember" type="checkbox" value="y">
                <label class="form-check-label" for="remember">Remember Me</label>
            </div>
            
            <div class="form-group">
                <input class="btn btn-primary btn-block" id="submit" name="submit" type="submit" value="Login">
            </div>
        </form>
        <div class="auth-footer">
            <small>Need an account? <a href="/register">Sign Up Now</a></small>
        </div>
    </div>
</div>

            </main>

            </main>

            <footer class="premium-footer">
                <div class="container text-center">
                    <div class="mb-4">
                        <a href="#" class="text-muted mx-2 fs-5 transition-colors hover-primary"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-muted mx-2 fs-5 transition-colors hover-primary"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-muted mx-2 fs-5 transition-colors hover-primary"><i class="fab fa-facebook"></i></a>
