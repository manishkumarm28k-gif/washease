                                </a>
                                <a href="#" class="nav-dropdown-item nav-item-disabled">
                                    Deoghar <span class="store-badge" style="background: #f1f5f9; color: #64748b;">SOON</span>
                                </a>
                            </div>
                        </div>

                        <a href="/services" style="text-decoration: none; color: #0f172a;">Pricing</a>
